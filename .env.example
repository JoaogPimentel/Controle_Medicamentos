# Credenciais do PostgreSQL usado pelo docker-compose.
# Copie para ".env" (não versionado) e ajuste se necessário.
POSTGRES_DB=devweb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Variáveis lidas pela aplicação Java (ConnectionPool).
# Use-as no lugar de src/main/resources/db.properties.
DB_URL=jdbc:postgresql://localhost:5432/devweb
DB_USER=postgres
DB_PASSWORD=postgres

# Segredo de assinatura do JWT (HS256). Defina um valor forte em produção.
JWT_SECRET=troque-por-um-segredo-forte

# Origens permitidas para CORS (separadas por vírgula). Sem valor, libera só o Vite local.
# Ex.: https://usuario.github.io,http://localhost:5173
CORS_ORIGIN=http://localhost:5173
