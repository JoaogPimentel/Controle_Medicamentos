# Origem da API consumida pelo front.
#
# Em desenvolvimento, deixe vazio ou não crie o .env: as chamadas usam caminhos
# relativos (/api/...) e o proxy do Vite encaminha para http://localhost:8080.
#
# No build de produção (GitHub Pages), defina a URL da API. Como a API Java roda
# localmente, aponte para o localhost (exceção ao bloqueio de mixed-content):
# VITE_API_BASE=http://localhost:8080
VITE_API_BASE=
